{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ARDA HUD",
  "version": "0.1.0",
  "identifier": "com.arda.hud",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": null,
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ARDA HUD",
        "label": "main",
        "width": 1280,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": true,
        "decorations": false,
        "transparent": true,
        "focus": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: tauri:",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*",
        "frame-src": "http://127.0.0.1:* http://localhost:*",
        "img-src": "'self' asset: data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "object-src": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
